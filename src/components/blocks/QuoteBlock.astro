---
interface Props {
  text: string;
  attribution?: string;
}

const { text, attribution } = Astro.props;
---

<figure class="quote-block">
  <blockquote class="quote-block__text">{text}</blockquote>
  {attribution && <figcaption class="quote-block__attribution">— {attribution}</figcaption>}
</figure>

<style>
.quote-block {
  border-left: 4px solid var(--color-red);
  padding: 1.5rem 1rem;
  margin: 2rem auto;
  background: var(--color-paper-alt);
  font-style: italic;
  max-width: var(--max-width);
  margin-inline: auto;
}

.quote-block__text {
  font-size: 1.25rem;
  line-height: 1.7;
  color: var(--color-ink);
  margin: 0;
}

.quote-block__attribution {
  font-size: 0.9rem;
  color: var(--color-muted);
  font-style: normal;
  margin-top: 1rem;
  text-align: right;
}
</style>
